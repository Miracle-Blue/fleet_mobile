{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Dependencies",
      "type": "shell",
      "command": [
        "(flutter pub get)",
        "&& (flutter pub get --directory=packages/local_source/)",
        "&& (flutter pub get --directory=packages/localization/)",
        "&& (flutter pub get --directory=packages/ui/)"
      ],
      "group": {
        "kind": "none",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "Generate Localization",
      "type": "shell",
      "command": [
        "dart pub global activate sheety_localization",
        "&& dart pub global run sheety_localization:generate",
        "--credentials=packages/localization/credentials.json",
        "--sheet=1RX3JQhQNR4PW-63cMmefwOtjViqZn2HO_HggSJF9R58",
        "--lib=./packages/localization/lib/",
        "--arb=src/l10n",
        "--gen=src/generated",
        "--prefix=intl",
        "--format"
      ],
      "options": {
        "cwd": "${workspaceFolder}/packages/localization"
      },
      "problemMatcher": []
    }
  ]
}
